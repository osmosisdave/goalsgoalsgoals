{
  "name": "ggg-server",
  "version": "1.0.0",
  "main": "dist/server.js",
  "license": "MIT",
  "dependencies": {
    "axios": "1.13.4",
    "bcryptjs": "2.4.3",
    "body-parser": "1.20.4",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "fs-extra": "11.3.2",
    "googleapis": "171.4.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "5.9.2"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsc && node dist/server.js",
    "watch": "tsc --watch",
    "list-users": "node list_users.js",
    "create-admin": "node create_admin.js",
    "clear-selections": "node clear_mock_match_selections.js",
    "seed-selections": "node seed_mock_match_selections.js",
    "reseed-selections": "node clear_mock_match_selections.js && node seed_mock_match_selections.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.2.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
